pipeline {
    agent any
    tools {
        maven 'maven3'
        jdk 'jdk21'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Sonar Analysis') {
            steps {
                sh 'mvn clean compile -DskipTests'
                sh 'mvn org.sonarsource.scanner.maven:sonar-maven-plugin:4.0.0.4121:sonar \
                    -Dsonar.host.url=http://13.50.246.94:9000 \
                    -Dsonar.token=squ_093817fe64b396b3ca8ad1642543582ec70b6b87 \
                    -Dsonar.projectKey=simple-java-maven-app'
            }
        }
        // THIS IS THE BUILD STAGE
        stage('Build') {
            steps {
                // This creates the actual JAR file in the target folder
                sh 'mvn clean package -DskipTests' 
            }
        }
    }
}
